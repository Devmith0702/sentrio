{
  "name": "sentrio",
  "version": "1.0.0",
  "description": "Sentrio — AI-powered fake banking site detector for Sri Lankan users",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "clean": "rm -rf dist .parcel-cache",
    "build:popup": "parcel build src/ui/popup.html --dist-dir dist/ui --no-source-maps",
    "build:overlay": "parcel build src/ui/overlay-inject.js --dist-dir dist/ui --no-source-maps",
    "build:trust": "parcel build src/trustProfileBundle.js --dist-dir dist --no-source-maps",
    "build": "npm run clean && npm run build:popup && npm run build:overlay && npm run build:trust",
    "build:test": "parcel build src/ui/test.html --dist-dir dist/test --no-source-maps",
    "watch:overlay": "parcel watch src/ui/overlay-inject.js --dist-dir dist/ui",
    "watch:trust": "parcel watch src/trustProfileBundle.js --dist-dir dist",
    "test": "node test.integration.js && node test.browser-sim.js",
    "verify": "npm run build && npm test"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "parcel": "^2.12.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "puppeteer-core": "^25.1.0"
  },
  "browserslist": "> 0.5%, last 2 Chrome versions, not dead",
  "@parcel/transformer-js": {
    "inlineFS": false
  }
}
